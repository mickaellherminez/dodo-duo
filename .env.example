# ============================================================================
# Application
# ============================================================================

APP_NAME="Dodo Duo" # Human-readable application name shown in the UI, emails, and logs.

APP_ENV=local # Runtime environment (`local`, `staging`, `production`, `testing`).

APP_KEY= # Laravel encryption key (leave empty, then run `php artisan key:generate`).

APP_DEBUG=true # Enable verbose debug output (`true` for local, `false` for production).

APP_TIMEZONE=UTC # Default app timezone (IANA timezone string, e.g. `UTC`, `Europe/Paris`).

APP_URL=http://localhost # Base application URL used for URL generation, callbacks, and links.

APP_VERSION=0.32.0 # Project/application version string (semantic or release tag).

APP_LOCALE=en # Default locale for translations (e.g. `en`, `fr`).

APP_FALLBACK_LOCALE=en # Locale used when a translation key is missing.

APP_FAKER_LOCALE=en_US # Faker locale used by factories/seeders in development/tests.

APP_MAINTENANCE_DRIVER=file # Maintenance mode backend (`file` or `database`).

APP_MAINTENANCE_STORE=database # Cache store used when `APP_MAINTENANCE_DRIVER=database`.

PHP_CLI_SERVER_WORKERS=4 # Worker count for `php artisan serve` in local development.

BCRYPT_ROUNDS=12 # Password hashing cost factor (higher = slower, stronger).

# ============================================================================
# Logging
# ============================================================================

LOG_CHANNEL=stack # Primary log channel (`stack`, `single`, `daily`, etc.).

LOG_STACK=single # Comma-separated channels used when `LOG_CHANNEL=stack`.

LOG_DEPRECATIONS_CHANNEL=null # Channel for PHP/Laravel deprecation logs (`null` disables dedicated channel).

LOG_LEVEL=debug # Minimum log level (`debug`, `info`, `warning`, `error`, ...).

# ============================================================================
# Database
# ============================================================================

DB_CONNECTION=mysql # Database driver (`mysql`, `sqlite`, `pgsql`, `sqlsrv`).

DB_HOST=127.0.0.1 # Database host (ignored for SQLite file-based setups).

DB_PORT=3306 # Database port (`3306` for MySQL, `5432` for PostgreSQL).

DB_DATABASE=saas_forge # Database name, or absolute SQLite file path when using `sqlite`.

DB_USERNAME=root # Database username (unused for SQLite).

DB_PASSWORD= # Database password (unused for SQLite; keep empty locally if applicable).

# ============================================================================
# Session
# ============================================================================

SESSION_DRIVER=database # Session backend (`database`, `file`, `cookie`, `redis`, `array`).

SESSION_LIFETIME=120 # Session lifetime in minutes.

SESSION_ENCRYPT=false # Encrypt session payloads at rest (`true`/`false`).

SESSION_PATH=/ # Cookie path for session cookie scope (usually `/`).

SESSION_DOMAIN=null # Cookie domain override (e.g. `.example.com`) or `null`.

# ============================================================================
# Broadcast / Filesystem / Queue
# ============================================================================

BROADCAST_CONNECTION=log # Broadcasting driver (`log`, `pusher`, `ably`, `reverb`, `null`).

FILESYSTEM_DISK=local # Default filesystem disk (`local`, `public`, `s3`, ...).

QUEUE_CONNECTION=database # Queue backend (`database`, `redis`, `sync`, `sqs`, ...).

# ============================================================================
# Cache
# ============================================================================

CACHE_STORE=file # Default cache store (`file`, `database`, `redis`, `memcached`, `array`).

CACHE_PREFIX= # Prefix for cache keys (blank = framework-generated prefix).

MEMCACHED_HOST=127.0.0.1 # Memcached host when using memcached cache/session/queue backends.

REDIS_CLIENT=phpredis # Redis PHP client (`phpredis` or `predis` if installed).

REDIS_HOST=127.0.0.1 # Redis server host.

REDIS_PASSWORD=null # Redis password or `null` if authentication is disabled.

REDIS_PORT=6379 # Redis server port (default `6379`).

# ============================================================================
# Mail
# ============================================================================

MAIL_MAILER=log # Mail transport (`log`, `smtp`, `sendmail`, `ses`, `resend`, ...).

RESEND_KEY= # API key used when `MAIL_MAILER=resend`.

MAIL_SCHEME=null # SMTP scheme (`null`, `tls`, `ssl`) depending on provider requirements.

MAIL_HOST=127.0.0.1 # SMTP host or provider endpoint.

MAIL_PORT=2525 # SMTP port (common values: `25`, `465`, `587`, `2525`).

MAIL_USERNAME=null # SMTP username or API login identifier.

MAIL_PASSWORD=null # SMTP password or provider token.

MAIL_FROM_ADDRESS="hello@example.com" # Default sender email address.

MAIL_FROM_NAME="${APP_NAME}" # Default sender display name (supports other env refs).

# ============================================================================
# AWS / S3 (Optional)
# ============================================================================

AWS_ACCESS_KEY_ID= # AWS access key for S3 or related integrations.

AWS_SECRET_ACCESS_KEY= # AWS secret key paired with `AWS_ACCESS_KEY_ID`.

AWS_DEFAULT_REGION=us-east-1 # AWS region (e.g. `us-east-1`, `eu-west-1`).

AWS_BUCKET= # S3 bucket name used by the `s3` filesystem disk.

AWS_USE_PATH_STYLE_ENDPOINT=false # `true` for MinIO/path-style endpoints, `false` for standard S3 virtual-host style.

# ============================================================================
# Frontend / Vite
# ============================================================================

VITE_APP_NAME="${APP_NAME}" # App name exposed to Vite-built frontend assets.

# ============================================================================
# Sanctum
# ============================================================================

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000 # Comma-separated local/frontend domains allowed for stateful SPA auth.

SANCTUM_TOKEN_EXPIRATION=1440 # API token lifetime in minutes (`null` for no expiration; `1440` = 24h).

# ============================================================================
# Workspace (Multi-Tenancy)
# ============================================================================

WORKSPACE_APP_DOMAIN=saasforge.local # Base app domain used for subdomain workspace resolution (e.g. `acme.<domain>`).

WORKSPACE_VERIFY_ACCESS=true # Verify authenticated user membership/ownership for resolved workspace (`true`/`false`).

# ============================================================================
# OAuth (Social Login)
# ============================================================================

GOOGLE_CLIENT_ID= # Google OAuth client ID from Google Cloud Console.

GOOGLE_CLIENT_SECRET= # Google OAuth client secret.

GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/google/callback" # Full callback URL registered for Google OAuth.

GITHUB_CLIENT_ID= # GitHub OAuth app/client ID.

GITHUB_CLIENT_SECRET= # GitHub OAuth app/client secret.

GITHUB_REDIRECT_URI="${APP_URL}/api/v1/auth/github/callback" # Full callback URL registered for GitHub OAuth.

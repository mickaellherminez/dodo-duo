# SaaSForge - Production Environment Template
# Copy this file to .env on your production server and fill in real values.
# NEVER commit .env (only .env.production.example as template).
#
# Shared Hosting (mutualisé) Optimizations:
# - File cache: works on all plans, no Redis required
# - File session: works on all plans, no Redis required
# - Database queue: MySQL already required, no extra service
# - Single log file: reduces file I/O and log rotation overhead
# - Warning log level: avoids disk writes for debug/info messages in production
# - Bcrypt rounds=10: faster auth on constrained CPU (vs default 12)

# ============================================================
# Application
# ============================================================
APP_NAME=SaaSForge
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_VERSION=0.26.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

# ============================================================
# Security
# Bcrypt rounds: 10 balances security and CPU on shared hosting
# (Laravel default is 12; lower = faster, still secure)
# ============================================================
BCRYPT_ROUNDS=10

# ============================================================
# Logging
# Single file channel minimizes I/O on shared hosting.
# Warning level skips debug/info writes in production.
# ============================================================
LOG_CHANNEL=single
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ============================================================
# Database (MySQL - standard on shared hosting)
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# ============================================================
# Cache
# CACHE_STORE=file: works on all mutualisé plans without Redis.
# Switch to redis if your host provides it (better performance).
# Note: Laravel 11 uses CACHE_STORE (not CACHE_DRIVER).
# ============================================================
CACHE_STORE=file
CACHE_PREFIX=saasforge

# ============================================================
# Session
# File driver: no Redis required on shared hosting.
# SESSION_ENCRYPT=false: HTTPS already encrypts transit;
# disabling session encryption gives a minor CPU saving.
# ============================================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================================
# Queue
# Database driver: no external queue service required.
# Cron job on server runs: php artisan queue:work --stop-when-empty
# ============================================================
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=null

# ============================================================
# Filesystem
# ============================================================
FILESYSTEM_DISK=local
ASSET_URL=https://yourdomain.com

# ============================================================
# Mail (configure for your hosting provider's SMTP)
# ============================================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your_email_password
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# Sanctum (API Authentication)
# Token expiration in minutes (1440 = 24 hours)
# ============================================================
SANCTUM_STATEFUL_DOMAINS=yourdomain.com
SANCTUM_TOKEN_EXPIRATION=1440

# ============================================================
# Multi-Tenancy
# ============================================================
WORKSPACE_APP_DOMAIN=yourdomain.com

# ============================================================
# OAuth (optional - configure if using social login)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/google/callback"

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/api/v1/auth/github/callback"

# ============================================================
# Redis (optional - uncomment if your host provides Redis)
# If enabled: change CACHE_STORE=redis and QUEUE_CONNECTION=redis
# ============================================================
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ============================================================
# AWS (optional - only if using S3 or SQS)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
